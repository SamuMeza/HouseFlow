# Set default behavior to handle line endings automatically.
* text=auto eol=lf

# Explicitly declare files that should always use LF (common in JS/TS projects)
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
.gitignore text eol=lf

# Use CRLF for specific Windows files if needed (usually not necessary in web projects)
# *.bat text eol=crlf
# *.ps1 text eol=crlf

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
